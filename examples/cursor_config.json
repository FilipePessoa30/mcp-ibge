{
  "mcpServers": {
    "ibge": {
      "command": "uvx",
      "args": ["mcp-ibge"]
    },
    "ibge-windows": {
      "command": "cmd",
      "args": ["/c", "uvx", "mcp-ibge"]
    },
    "ibge-dev": {
      "command": "uv",
      "args": [
        "--directory",
        "/caminho/absoluto/para/mcp-ibge",
        "run",
        "mcp-ibge"
      ]
    }
  }
}
