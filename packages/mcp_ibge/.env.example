# Configuração do servidor MCP mcp-ibge.
# Copie este arquivo para ".env" e ajuste o que precisar — todos os valores
# abaixo já são os padrões e podem ser omitidos.

# URL base comum às APIs públicas do IBGE (não exige chave de API). Cada
# cliente acrescenta seu próprio prefixo de versão/recurso (ex.:
# "/v1/localidades", "/v3/agregados").
MCP_IBGE_API_BASE_URL=https://servicodados.ibge.gov.br/api

# Identificação usada nos metadados de resposta e no header User-Agent.
MCP_IBGE_SOURCE_NAME=IBGE - Instituto Brasileiro de Geografia e Estatística
MCP_IBGE_USER_AGENT=mcp-ibge/0.1.0

# URL institucional da fonte oficial dos dados (metadata.official_source).
MCP_IBGE_OFFICIAL_SOURCE_URL=https://www.ibge.gov.br/

# Nota de licença/uso incluída em metadata.license_note de toda resposta.
MCP_IBGE_LICENSE_NOTE=Dados públicos do IBGE (Instituto Brasileiro de Geografia e Estatística). Verifique a fonte oficial antes de uso em relatórios ou decisões.

# Timeout (segundos) para cada requisição às APIs do IBGE.
MCP_IBGE_TIMEOUT=30.0

# Tamanho máximo (bytes) aceito para o corpo de uma resposta da API do IBGE.
MCP_IBGE_MAX_RESPONSE_SIZE_BYTES=5000000

# Cache em memória (TTL) para reduzir chamadas repetidas às APIs.
# MCP_DATA_BR_ENABLE_CACHE / MCP_DATA_BR_CACHE_TTL_SECONDS são nomes
# compartilhados entre módulos do mcp-data-br e têm precedência sobre
# MCP_IBGE_CACHE_ENABLED / MCP_IBGE_CACHE_TTL_SECONDS, mantidos por
# compatibilidade.
MCP_IBGE_CACHE_ENABLED=true
MCP_IBGE_CACHE_TTL_SECONDS=3600.0
MCP_IBGE_CACHE_MAX_SIZE=256
# MCP_DATA_BR_ENABLE_CACHE=true
# MCP_DATA_BR_CACHE_TTL_SECONDS=3600.0

# Nível de log (DEBUG, INFO, WARNING, ERROR), emitido como JSON em stderr.
# MCP_DATA_BR_LOG_LEVEL tem precedência sobre MCP_IBGE_LOG_LEVEL, mantido por
# compatibilidade.
MCP_IBGE_LOG_LEVEL=INFO
# MCP_DATA_BR_LOG_LEVEL=INFO

# Transporte MCP.
MCP_IBGE_TRANSPORT=stdio

# Porta usada quando MCP_IBGE_TRANSPORT=streamable-http (ignorada em stdio).
MCP_IBGE_PORT=8000
